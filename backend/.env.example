# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/parapharmacie"

# ===========================================
# Configuration de la Base de Données PostgreSQL
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/parapharmacie"

# ===========================================
# Configuration du Serveur
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# Configuration JWT (JSON Web Token)
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ===========================================
# Configuration des Emails (Nodemailer)
# ===========================================
# Option 1: Configuration Gmail (recommandé pour le développement)
# Pour utiliser Gmail, vous devez créer un "App Password" dans les paramètres de sécurité Google
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option 2: Configuration SMTP personnalisée (pour production)
# Décommentez ces lignes et commentez l'option Gmail ci-dessus
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=your_phone_number
