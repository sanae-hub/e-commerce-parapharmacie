# ===========================================
# Fichier de configuration .env.example du Backend
# Projet e-commerce-parapharmacie
# ===========================================

# ===========================================
# Configuration de la Base de Données PostgreSQL
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/parapharmacie"

# ===========================================
# Configuration du Serveur
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# Configuration JWT (JSON Web Token)
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ===========================================
# Configuration des Emails (Nodemailer)
# ===========================================
# Option 1: Configuration Gmail (recommandé pour le développement)
# Pour utiliser Gmail, vous devez créer un "App Password" dans les paramètres de sécurité Google
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option 2: Configuration SMTP personnalisée (pour production)
# Décommentez ces lignes et commentez l'option Gmail ci-dessus
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# ===========================================
# Notes pour la configuration des emails :
# ===========================================
# 1. Pour Gmail :
#    - Activez la vérification en deux étapes sur votre compte Google
#    - Générez un "App Password" dans Paramètres > Sécurité
#    - Utilisez ce mot de passe d'application dans EMAIL_PASSWORD
#
# 2. Pour un serveur SMTP personnalisé :
#    - SMTP_HOST: adresse du serveur SMTP (ex: smtp.gmail.com)
#    - SMTP_PORT: port du serveur (587 pour TLS, 465 pour SSL)
#    - SMTP_SECURE: true pour SSL (port 465), false pour TLS (port 587)
#
# 3. Les notifications par email sont envoyées pour :
#    - Confirmation de commande
#    - Changements de statut de commande
#    - Réinitialisation de mot de passe
#    - Rappels de créneau Click & Collect (2h avant)
