// NOUVEAU SCHÉMA SÉCURISÉ - Tables séparées par type d'utilisateur
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// ==================== CLIENTS (Données publiques limitées) ====================
model Client {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  address           String?
  whatsapp          String?
  profileImage      String?
  notificationEmail Boolean   @default(true)
  notificationSMS   Boolean   @default(false)
  notificationWhatsApp Boolean @default(false)
  notificationPush  Boolean   @default(true)
  isActive          Boolean   @default(true)
  resetToken        String?
  resetTokenExpiry  DateTime?
  deleteCode        String?
  deleteCodeExpiry  DateTime?
  authProvider      String    @default("local")
  cart              Json?     @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations spécifiques aux clients
  orders           Order[]
  favorites        Favorite[]
  reviews          Review[]
  searchHistory    SearchHistory[]
  notifications    Notification[]

  @@index([email])
  @@index([isActive])
}

// ==================== EMPLOYÉS (Données internes) ====================
model Employee {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  phone            String?
  employeeId       String?   @unique
  department       String?
  position         String?
  salary           Float?
  hireDate         DateTime?
  isActive         Boolean   @default(true)
  pin              String?   // Code PIN hashé pour opérations critiques
  resetToken       String?
  resetTokenExpiry DateTime?
  pinResetCode     String?   // Code envoyé par email pour reset mot de passe
  pinResetExpiry   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations spécifiques aux employés
  permissions      EmployeePermission[]
  timeSlotConfigs  TimeSlotConfig[] @relation("EmployeeTimeSlots")
  slotReservations EmployeeSlotReservation[] @relation("EmployeeSlotReservations")
  processedOrders  Order[] @relation("EmployeeOrders")
  resolvedConflicts SlotConflict[] @relation("SlotConflictResolver")
  auditLogs        AuditLog[]

  @@index([email])
  @@index([employeeId])
  @@index([isActive])
}

// ==================== ADMINISTRATEURS (Données ultra-sensibles) ====================
model Admin {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  phone            String?
  isSuperAdmin     Boolean   @default(false)
  lastLoginAt      DateTime?
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  isActive         Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations spécifiques aux admins
  auditLogs        AuditLog[] @relation("AdminAuditLogs")

  @@index([email])
  @@index([isSuperAdmin])
}

// ==================== PERMISSIONS EMPLOYÉS ====================
model EmployeePermission {
  id        String   @id @default(uuid())
  employeeId String
  module    String   // "products", "orders", "reports", etc.
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, module])
  @@index([employeeId])
}

// ==================== AUDIT LOGS SÉCURISÉS ====================
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  // ID générique (peut être Client, Employee, ou Admin)
  userType    String   // "CLIENT", "EMPLOYEE", "ADMIN"
  employeeId  String?  // Référence spécifique employé
  adminId     String?  // Référence spécifique admin
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType  String   // User, Order, Product, etc.
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  description String
  createdAt   DateTime @default(now())

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  admin    Admin?    @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userType])
  @@index([entityType])
  @@index([createdAt])
}

// ==================== RESTE DU SCHÉMA (inchangé) ====================

model SearchHistory {
  id        String   @id @default(uuid())
  clientId  String
  query     String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model Category {
  id               String   @id @default(uuid())
  name             String   @unique
  icon             String?
  image            String?
  hasSubcategories Boolean  @default(false)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String   @id @default(uuid())
  title      String
  icon       String?
  image      String?
  categoryId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    SubcategoryItem[]
  products Product[]
}

model SubcategoryItem {
  id            String   @id @default(uuid())
  name          String
  subcategoryId String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  products    Product[]
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  logo        String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id                String   @id @default(uuid())
  name              String
  description       String?  @db.Text
  usage             String?  @db.Text
  composition       String?  @db.Text
  benefits          Json?    @default("[]")
  price             Float
  priceHT           Float    @default(0)
  priceTTC          Float    @default(0)
  taxRate           Float    @default(20)
  oldPrice          Float?
  oldPriceHT        Float?
  image             String?
  brand             String?
  brandId           String?
  sku               String?
  type              String?
  images            Json?    @default("[]")
  variants          Json?    @default("[]")
  barcode           String?
  rating            Float    @default(0)
  reviews           Int      @default(0)
  stock             Int      @default(0)
  stockAlert        Int      @default(10)
  categoryId        String
  subcategoryId     String?
  subcategoryItemId String?
  active            Boolean  @default(true)
  expiryDate        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category        Category          @relation(fields: [categoryId], references: [id])
  subcategory     Subcategory?      @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  subcategoryItem SubcategoryItem?  @relation(fields: [subcategoryItemId], references: [id], onDelete: SetNull)
  brandModel      Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  favorites       Favorite[]
  productReviews  Review[]          @relation("ProductReviews")
  productImages   ProductImage[]
  productVariants ProductVariant[]
  suppliers       ProductSupplier[]
  stockNotifications StockNotification[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@unique([barcode])
  @@unique([sku])
  @@unique([name, categoryId])
  @@index([brand, name])
  @@index([barcode])
  @@index([sku])
  @@index([active, categoryId])
  @@index([active, createdAt])
  @@index([name])
  @@index([categoryId, active, createdAt])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  publicId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model VariantType {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  values      VariantValue[]
  variants    ProductVariant[]
}

model VariantValue {
  id            String   @id @default(uuid())
  variantTypeId String
  value         String
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  
  variantType   VariantType    @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  variants      ProductVariant[]

  @@unique([variantTypeId, value])
  @@index([variantTypeId])
}

model ProductVariant {
  id              String   @id @default(uuid())
  productId       String
  variantTypeId   String?
  variantValueId String?
  type            String
  value           String
  priceHT         Float?
  priceTTC        Float?
  priceAdjustment Float    @default(0)
  stock           Int      @default(0)
  image           String?
  description     String?  @db.Text
  barcode         String?
  expiryDate      DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantType    VariantType?    @relation(fields: [variantTypeId], references: [id], onDelete: SetNull)
  variantValue   VariantValue?   @relation(fields: [variantValueId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@index([productId])
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  type      String
  quantity  Int
  reason    String?
  userId    String?
  createdAt DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([createdAt])
}

model Order {
  id              String    @id @default(uuid())
  clientId        String?   // Référence vers Client au lieu de User
  orderNumber     String?   @unique
  status          String    @default("RECEIVED")
  type            String    @default("CLICK_COLLECT")
  deliveryType    String    @default("STANDARD")
  deliveryPrice   Float     @default(0)
  total           Float     @default(0)
  timeSlotDate    DateTime?
  timeSlotStart   String?
  timeSlotEnd     String?
  deliveryAddress String?
  deliveryCityId  String?
  deliveryDistrictId String?
  deliveryStreet  String?
  deliveryPhone   String?
  deliveryInstructions String?
  cashAmount           Float?
  qrCode          String?   @db.Text
  reminderSent    Boolean   @default(false)
  isUrgent        Boolean   @default(false)
  employeeId      String?   // Référence vers Employee
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client           Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  employee         Employee?         @relation("EmployeeOrders", fields: [employeeId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  promoHistories   PromoHistory[]
  deliveryCity     DeliveryCity?     @relation(fields: [deliveryCityId], references: [id], onDelete: SetNull)
  deliveryDistrict DeliveryDistrict? @relation(fields: [deliveryDistrictId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([clientId])
  @@index([timeSlotDate])
  @@index([employeeId])
  @@index([clientId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  variantId     String?
  quantity      Int
  price         Float
  name          String?
  variantType   String?
  variantValue  String?

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([orderId, productId, variantId])
  @@index([orderId, productId])
}

model Favorite {
  id        String   @id @default(uuid())
  clientId  String   // Référence vers Client
  productId String
  createdAt DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([clientId, productId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  clientId  String?  // Référence vers Client
  name      String
  rating    Int
  comment   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([approved])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  clientId  String?  // Référence vers Client
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([read])
  @@index([type])
  @@index([clientId, read, createdAt])
}

// ==================== RESTE DES MODÈLES (inchangés) ====================

model PromoCode {
  id                String    @id @default(uuid())
  code              String    @unique
  description       String?
  discountType      String    @default("percentage")
  discountValue     Float
  applicableOn      String    @default("global")
  productIds        Json?     @default("[]")
  categoryIds       Json?     @default("[]")
  minPurchaseAmount Float?    @default(0)
  maxDiscountAmount Float?
  usageLimit        Int?
  usageCount        Int       @default(0)
  expiryDate        DateTime?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  promoHistory PromoHistory[]
}

model Promotion {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  subtitle      String?
  bannerImage   String?
  discountType  String   @default("percentage")
  discountValue Float
  oldPrice      Float?
  price         Float?
  stock         Int?
  rating        Float?
  productId     String?
  productName   String?
  productImage  String?
  badge         String?
  badgeColor    String?
  bgColor       String?
  iconName      String?
  features      Json?    @default("[]")
  ctaText       String?  @default("Profiter maintenant")
  active        Boolean  @default(true)
  order         Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stats PromotionStats?
}

model PromotionStats {
  id            String   @id @default(uuid())
  promotionId   String   @unique
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  totalDiscount Float    @default(0)
  ordersCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model PromoHistory {
  id              String   @id @default(uuid())
  promoCodeId     String
  orderId         String?
  numericCode     String
  appliedDiscount Float
  createdAt       DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
  @@index([createdAt])
  @@index([orderId])
}

model DeletedAccount {
  id        String   @id @default(uuid())
  email     String   @unique
  deletedAt DateTime @default(now())

  @@index([email])
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeliveryCity {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts DeliveryDistrict[]
  orders    Order[]
}

model DeliveryDistrict {
  id        String   @id @default(uuid())
  cityId    String
  name      String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city   DeliveryCity @relation(fields: [cityId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([cityId, name])
  @@index([cityId])
}

model DeliveryDayConfig {
  id        String   @id @default(uuid())
  dayOfWeek Int
  startTime String   @default("10:00")
  endTime   String   @default("18:00")
  capacity  Int      @default(7)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
}

model TimeSlotConfig {
  id              String   @id @default(uuid())
  dayOfWeek       Int
  startTime       String
  endTime         String
  capacity        Int      @default(5)
  intervalMinutes Int      @default(60)
  excludeHours    Json?    @default("[]")
  active          Boolean  @default(true)
  type            String   @default("STORE")
  employeeId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee? @relation("EmployeeTimeSlots", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([dayOfWeek, startTime])
  @@index([employeeId])
}

model SlotCapacityOverride {
  id        String   @id @default(uuid())
  dayOfWeek Int
  slotTime  String
  capacity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek, slotTime])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  date      DateTime
  startTime String?
  endTime   String?
  reason    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, startTime, endTime])
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  receiverId String
  content    String    @db.Text
  type       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Supplier {
  id          String   @id @default(uuid())
  name        String   @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  description String?  @db.Text
  deliveryDays Int     @default(3)
  paymentTerms String?
  autoDiscount Float?
  active      Boolean  @default(true)
  seuilRemise           Float?   @default(0)
  pourcentageRemiseSeuil Float?   @default(0)
  typeRemise            String?  @default("remise_immediate")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    ProductSupplier[]
  orders     PurchaseOrder[]
  discounts  SupplierDiscount[]
  purchases  SupplierPurchase[]
  credits    SupplierCredit[]
}

model ProductSupplier {
  id         String   @id @default(uuid())
  productId  String
  supplierId String
  price      Float
  reference  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
}

model StockNotification {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  notifiedAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([notified])
}

model EmployeeSlotReservation {
  id          String   @id @default(uuid())
  employeeId  String
  date        DateTime
  startTime   String
  endTime     String
  status      String @default("ACTIVE")
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation("EmployeeSlotReservations", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, startTime, endTime])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

model SlotConflict {
  id          String   @id @default(uuid())
  date        DateTime
  time        String
  conflictType String
  description String? @db.Text
  resolved    Boolean @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resolvedByEmployee Employee? @relation("SlotConflictResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

   @@index([date])
   @@index([resolved])
   @@index([createdAt])
}

model PurchaseOrder {
  id              String    @id @default(uuid())
  orderNumber     String    @unique
  supplierId      String
  status          String    @default("BROUILLON")
  totalAmount     Float     @default(0)
  discountAmount  Float     @default(0)
  paidAmount      Float     @default(0)
  notes           String?   @db.Text
  orderDate       DateTime  @default(now())
  sentDate        DateTime?
  expectedDate    DateTime?
  receivedDate   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items           PurchaseOrderItem[]
  supplierPurchases SupplierPurchase[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Float
  receivedQty     Int      @default(0)
  expiryDate      DateTime?
  batchNumber     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model SupplierDiscount {
  id              String   @id @default(uuid())
  supplierId      String
  name            String
  discountType    String   @default("PERCENTAGE")
  discountValue   Float
  minAmount       Float    @default(0)
  maxDiscount     Float?
  startDate       DateTime @default(now())
  endDate         DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchases       SupplierPurchase[]

  @@index([supplierId])
  @@index([active])
}

model SupplierPurchase {
  id                  String   @id @default(uuid())
  supplierId          String
  purchaseOrderId     String?
  discountId         String?
  amount             Float
  discountApplied    Float    @default(0)
  purchaseDate       DateTime @default(now())
  month               Int
  year                Int

  supplier            Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrder       PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  discount            SupplierDiscount? @relation(fields: [discountId], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([month, year])
}

model SupplierCredit {
  id          String    @id @default(uuid())
  supplierId  String
  amount      Float
  reason      String?   @db.Text
  expiresAt   DateTime
  used        Boolean   @default(false)
  usedAt      DateTime?
  usedInOrder String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([used])
  @@index([expiresAt])
}