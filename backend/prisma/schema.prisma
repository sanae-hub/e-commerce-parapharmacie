datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  address           String?
  whatsapp          String?
  profileImage      String?
  notificationEmail Boolean   @default(true)
  notificationSMS   Boolean   @default(false)
  notificationWhatsApp Boolean @default(false)
  notificationPush  Boolean   @default(true)
  role              String    @default("CLIENT") // CLIENT, ADMIN, PREPARATEUR, CAISSIER, EMPLOYE
  isActive          Boolean   @default(true)
  resetToken        String?
  resetTokenExpiry  DateTime?
  cart              Json?     @default("[]")
  salary           Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders           Order[]
  favorites        Favorite[]
  auditLogs        AuditLog[]
  reviews          Review[]
  sentMessages     Message[]  @relation("MessageSender")
  receivedMessages Message[]  @relation("MessageReceiver")
  searchHistory    SearchHistory[]
  timeSlotConfigs  TimeSlotConfig[] @relation("UserTimeSlots")
  employeeSlotReservations EmployeeSlotReservation[] @relation("EmployeeSlotReservations")
  employeeOrders   Order[] @relation("EmployeeOrders")
  resolvedConflicts SlotConflict[] @relation("SlotConflictResolver")
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String
  query     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Category {
  id               String   @id @default(uuid())
  name             String   @unique
  icon             String?
  image            String?
  hasSubcategories Boolean  @default(false)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String   @id @default(uuid())
  title      String
  icon       String?
  image      String?
  categoryId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    SubcategoryItem[]
  products Product[]
}

model SubcategoryItem {
  id            String   @id @default(uuid())
  name          String
  subcategoryId String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  products    Product[]
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  logo        String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id                String   @id @default(uuid())
  name              String
  description       String?  @db.Text
  usage             String?  @db.Text
  composition       String?  @db.Text
  benefits          Json?    @default("[]")
  price             Float // Keep for backward compatibility (maps to TTC)
  priceHT           Float    @default(0)
  priceTTC          Float    @default(0)
  taxRate           Float    @default(20)
  oldPrice          Float?
  oldPriceHT        Float?

  image             String?
  brand             String?
  brandId           String?
  sku               String?  // SKU (référence interne)
  type              String?
  images            Json?    @default("[]")
  variants          Json?    @default("[]")
  barcode           String?
  rating            Float    @default(0)
  reviews           Int      @default(0)
  stock             Int      @default(0)
  stockAlert        Int      @default(10)
  categoryId        String
  subcategoryId     String? // Sous-catégorie optionnelle
  subcategoryItemId String? // Item de sous-catégorie optionnel

  subcategory     Subcategory?     @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  subcategoryItem SubcategoryItem? @relation(fields: [subcategoryItemId], references: [id], onDelete: SetNull)
  active            Boolean  @default(true)
  expiryDate        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category        Category          @relation(fields: [categoryId], references: [id])
  brandModel      Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  favorites       Favorite[]
  productReviews  Review[]          @relation("ProductReviews")
  productImages   ProductImage[]
  productVariants ProductVariant[]
  suppliers       ProductSupplier[]
  stockNotifications StockNotification[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements StockMovement[]

  // Index d'unicité pour identifier le produit (ignore les null)
  @@unique([barcode])
  @@unique([sku])
  @@unique([name, categoryId])
  @@index([brand, name])
  @@index([barcode])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  publicId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Types de variantes dynamiques (créés par l'admin)
model VariantType {
  id          String   @id @default(uuid())
  name        String   @unique // volume, SPF, format, typeCheveux, typePeau, dosage, parfum
  label       String   // Label affiché (ex: "Volume", "Indice SPF")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  values      VariantValue[]
  variants    ProductVariant[]
}

model VariantValue {
  id            String   @id @default(uuid())
  variantTypeId String
  value         String   // La valeur (ex: "50ml", "50 SPF", "sec")
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  
  variantType   VariantType    @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  variants      ProductVariant[]

  @@unique([variantTypeId, value])
  @@index([variantTypeId])
}

model ProductVariant {
  id              String   @id @default(uuid())
  productId       String
  variantTypeId   String?
  variantValueId String?
  type            String
  value           String
  price           Float?   // Prix direct de la variante (remplace priceAdjustment)
  priceAdjustment Float    @default(0) // Gardé pour compatibilité
  stock           Int      @default(0)
  image           String?
  description     String?  @db.Text
  barcode         String?
  expiryDate      DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantType    VariantType?    @relation(fields: [variantTypeId], references: [id], onDelete: SetNull)
  variantValue   VariantValue?   @relation(fields: [variantValueId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@index([productId])
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  type      String
  quantity  Int
  reason    String?
  userId    String?
  createdAt DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([createdAt])
}

model Order {
  id              String    @id @default(uuid())
  userId          String?
  orderNumber     String?   @unique
  status          String    @default("RECEIVED")
  type            String    @default("CLICK_COLLECT")
  deliveryType    String    @default("STANDARD")
  deliveryPrice   Float     @default(0)
  total           Float     @default(0)
  timeSlotDate    DateTime?
  timeSlotStart   String?
  timeSlotEnd     String?
  deliveryAddress String?
  deliveryCityId  String?
  deliveryDistrictId String?
  deliveryStreet  String?
  deliveryPhone   String?
  deliveryInstructions String?
  qrCode          String?   @db.Text
  reminderSent    Boolean   @default(false)
  isUrgent        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  promoHistories  PromoHistory[]

  deliveryCity     DeliveryCity?     @relation(fields: [deliveryCityId], references: [id], onDelete: SetNull)
  deliveryDistrict DeliveryDistrict? @relation(fields: [deliveryDistrictId], references: [id], onDelete: SetNull)
  employeeId       String?
  employee         User?             @relation("EmployeeOrders", fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([timeSlotDate])
  @@index([employeeId])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  variantId     String? // ID de la variante si commande par variante
  quantity      Int
  price         Float
  name          String?
  variantType   String? // Type de variante (ex: "volume")
  variantValue  String? // Valeur de variante (ex: "50ml")

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Allow multiple variants of the same product in one order.
  // For non-variant items (variantId = null), the API consolidates duplicates before insert.
  @@unique([orderId, productId, variantId])
  @@index([orderId, productId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model PromoCode {
  id                String    @id @default(uuid())
  code              String    @unique
  description       String?
  discountType      String    @default("percentage") // percentage ou fixed
  discountValue     Float // Pourcentage (0-100) ou montant fixe
  applicableOn      String    @default("global") // global, product, category
  productIds        Json?     @default("[]") // Pour applicableOn=product
  categoryIds       Json?     @default("[]") // Pour applicableOn=category
  minPurchaseAmount Float?    @default(0)
  maxDiscountAmount Float? // Montant max de réduction
  usageLimit        Int? // Nombre max d'utilisations
  usageCount        Int       @default(0) // Nombre d'utilisations actuelles
  expiryDate        DateTime? // Date d'expiration
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  promoHistory PromoHistory[]
}

// backend/prisma/schema.prisma
// Modèle Promotion complet

// backend/prisma/schema.prisma

model Promotion {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  subtitle      String?
  bannerImage   String?
  discountType  String   @default("percentage")
  discountValue Float
  oldPrice      Float?
  price         Float?
  stock         Int?
  rating        Float?
  productId     String?
  productName   String?
  productImage  String?
  badge         String?
  badgeColor    String?
  bgColor       String?
  iconName      String?
  features      Json?    @default("[]")
  ctaText       String?  @default("Profiter maintenant")
  active        Boolean  @default(true)
  order         Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stats PromotionStats?
}

model PromotionStats {
  id            String   @id @default(uuid())
  promotionId   String   @unique
  impressions   Int      @default(0) // Nombre de fois la bannière vue
  clicks        Int      @default(0) // Nombre de clics
  conversions   Int      @default(0) // Nombre d'achats
  totalDiscount Float    @default(0) // Montant total remboursé
  ordersCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model PromoHistory {
  id              String   @id @default(uuid())
  promoCodeId     String
  orderId         String?
  numericCode     String // Code unique pour traçabilité
  appliedDiscount Float // Montant réel de réduction
  createdAt       DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
  @@index([createdAt])
  @@index([orderId])
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== LIVRAISON À DOMICILE : ZONES & CAPACITÉS ====================

model DeliveryCity {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts DeliveryDistrict[]
  orders    Order[]
}

model DeliveryDistrict {
  id        String   @id @default(uuid())
  cityId    String
  name      String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city   DeliveryCity @relation(fields: [cityId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([cityId, name])
  @@index([cityId])
}

// Capacité de livraison par jour (par jour de semaine), configurable par l'admin
model DeliveryDayConfig {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Dimanche, 1 = Lundi, etc.
  startTime String   @default("10:00") // fenêtre livraison
  endTime   String   @default("18:00")
  capacity  Int      @default(7)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
}

model TimeSlotConfig {
  id              String   @id @default(uuid())
  dayOfWeek       Int // 0 = Dimanche, 1 = Lundi, etc.
  startTime       String // Format HH:MM
  endTime         String // Format HH:MM
  capacity        Int      @default(5) // Capacité par défaut pour tous les créneaux du jour
  intervalMinutes Int      @default(60)
  excludeHours    Json?    @default("[]") // Heures à exclure (ex: [13, 14] pour pause 13-15)
  active          Boolean  @default(true)
  type            String   @default("STORE") // STORE, EMPLOYEE
  userId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation("UserTimeSlots", fields: [userId], references: [id], onDelete: Cascade)

  // Index sur dayOfWeek et startTime pour recherche rapide
  @@index([dayOfWeek, startTime])
  @@index([userId])
}

// Capacité spécifique par créneau horaire (override du défaut du jour)
model SlotCapacityOverride {
  id        String   @id @default(uuid())
  dayOfWeek Int // 0-6
  slotTime  String // Format HH:MM (heure de début du créneau)
  capacity  Int // Capacité spécifique pour ce créneau
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek, slotTime])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  date      DateTime // Date complète (YYYY-MM-DD)
  startTime String? // Format HH:MM, null = journée entière
  endTime   String? // Format HH:MM, null = journée entière
  reason    String // Raison du blocage (fermeture exceptionnelle, jour férié, etc.)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, startTime, endTime])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entityType  String // User, Order, Product, etc.
  entityId    String? // ID de l'entité concernée
  oldValues   Json? // Valeurs avant modification
  newValues   Json? // Valeurs après modification
  ipAddress   String?
  userAgent   String?
  description String // Description de l'action
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model Message {
  id         String    @id @default(uuid())
  senderId   String // User ID or Admin ID
  receiverId String // User ID or Admin ID  
  content    String    @db.Text
  type       String // 'USER_TO_ADMIN', 'ADMIN_TO_USER'
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// ==================== MODÈLES POUR LES AVIS ====================

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  name      String
  rating    Int
  comment   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([approved])
}

// ==================== MODÈLES POUR LES FOURNISSEURS ====================

model Supplier {
  id          String   @id @default(uuid())
  name        String   @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  description String?  @db.Text
  deliveryDays Int     @default(3) // Délai de livraison en jours
  paymentTerms String?  // Conditions de paiement (ex: "30 jours fin de mois")
  autoDiscount Float?   // Pourcentage de remise immédiate
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Nouveaux champs pour les remises automatiques
  seuilRemise           Float?   @default(0)  // Seuil minimum pour remise (ex: 1000 DH)
  pourcentageRemiseSeuil Float?   @default(0)  // Pourcentage de remise si seuil atteint (ex: 5%)
  typeRemise            String?  @default("remise_immediate") // "remise_immediate" ou "avoir_fin_mois"

  products    ProductSupplier[]
  orders     PurchaseOrder[]
  discounts  SupplierDiscount[]
  purchases  SupplierPurchase[]
  credits    SupplierCredit[]
}

model ProductSupplier {
  id         String   @id @default(uuid())
  productId  String
  supplierId String
  price      Float // Prix d'achat
  reference  String? // Référence fournisseur
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
}

// Notifications de retour en stock
model StockNotification {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  notifiedAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([notified])
}


// Réservations d'employés pour les créneaux
model EmployeeSlotReservation {
  id          String   @id @default(uuid())
  employeeId  String
  date        DateTime // Date complète
  startTime   String // Format HH:MM
  endTime     String // Format HH:MM
  status      String @default("ACTIVE") // ACTIVE, CANCELLED, ON_LEAVE
  reason      String? // Raison si congé ou annulation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee User @relation("EmployeeSlotReservations", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, startTime, endTime])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

// Historique des conflits de créneaux
model SlotConflict {
  id          String   @id @default(uuid())
  date        DateTime // Date du conflit
  time        String // Format HH:MM
  conflictType String // OVER_CAPACITY, SCHEDULE_MISMATCH, EMPLOYEE_UNAVAILABLE
  description String? @db.Text
  resolved    Boolean @default(false)
  resolvedAt  DateTime?
  resolvedBy  String? // ID de l'admin qui a résolu
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resolvedByUser User? @relation("SlotConflictResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([resolved])
  @@index([createdAt])
// ==================== MODÈLES POUR LES ACHATS/FOURNISSEURS ====================

model PurchaseOrder {
  id              String    @id @default(uuid())
  orderNumber     String    @unique
  supplierId      String
  status          String    @default("BROUILLON") // BROUILLON, VALIDÉ, ENVOYÉ, REÇU_PARTIEL, REÇU_TOTAL, ANNULÉ, VALIDATION_ATTENTE
  totalAmount     Float     @default(0)
  discountAmount  Float     @default(0)  // Montant de la remise appliquée
  paidAmount      Float     @default(0)
  notes           String?   @db.Text
  orderDate       DateTime  @default(now())
  sentDate        DateTime?
  expectedDate    DateTime?
  receivedDate   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items           PurchaseOrderItem[]
  supplierPurchases SupplierPurchase[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Float    // Prix d'achat unitaire
  receivedQty     Int      @default(0)
  expiryDate      DateTime?
  batchNumber     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model SupplierDiscount {
  id              String   @id @default(uuid())
  supplierId      String
  name            String   // Nom de la remise (ex: "Remise volume")
  discountType    String   @default("PERCENTAGE") // PERCENTAGE ou FIXED
  discountValue   Float    // Pourcentage (0-100) ou montant fixe
  minAmount       Float    @default(0) // Montant minimum d'achat
  maxDiscount     Float?   // Montant maximum de réduction
  startDate       DateTime @default(now())
  endDate         DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchases       SupplierPurchase[]

  @@index([supplierId])
  @@index([active])
}

model SupplierPurchase {
  id                  String   @id @default(uuid())
  supplierId          String
  purchaseOrderId     String?
  discountId         String?
  amount             Float    // Montant de l'achat
  discountApplied    Float    @default(0) // Montant de la remise appliquée
  purchaseDate       DateTime @default(now())
  month               Int      // Mois (1-12)
  year                Int      // Année

  supplier            Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrder       PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  discount            SupplierDiscount? @relation(fields: [discountId], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([month, year])
}

model SupplierCredit {
  id          String    @id @default(uuid())
  supplierId  String
  amount      Float     // Montant de l'avoir
  reason      String?   @db.Text // Motif de l'avoir
  expiresAt   DateTime  // Date d'expiration
  used        Boolean   @default(false) // Si l'avoir a été utilisé
  usedAt      DateTime?
  usedInOrder String?   // ID du bon de commande où l'avoir a été utilisé
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
