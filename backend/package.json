    "passport-facebook": "^3.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^5.8.0",
    "psql": "^0.0.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
