{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:cluster": "node src/cluster.js",
    "dev": "nodemon src/server.js",
    "migrate": "prisma migrate dev",
    "seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "perf": "run-perf-tests.bat",
    "perf:smoke": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/01_public_endpoints.js",
    "perf:auth": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/02_auth.js",
    "perf:orders": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/03_orders.js",
    "perf:admin": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/04_admin_dashboard.js",
    "perf:journey": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/05_user_journey.js",
    "perf:stress": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/06_stress.js",
    "perf:200users": "node k6.js run --env BASE_URL=http://localhost:5000 --env TEST_EMAIL=admin@parapharmacie.ma --env TEST_PASSWORD=Admin1234! tests/performance/07_load_200_users.js",
    "perf:spike": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/08_spike_promo_flash.js",
    "perf:endurance": "node k6.js run --env BASE_URL=http://localhost:5000 tests/performance/09_endurance.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
