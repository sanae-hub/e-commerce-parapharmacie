    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "i18next": "^26.0.3",
    "i18next-fs-backend": "^2.6.3",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.10.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
